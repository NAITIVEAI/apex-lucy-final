# Azure OpenAI (legacy)
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_ENDPOINT=https://your-endpoint.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# Azure AI Foundry
AZURE_AI_PROJECT_ENDPOINT=https://your-foundry-resource.services.ai.azure.com/api/projects/your-project
AZURE_AI_FOUNDRY_PROJECT_ENDPOINT=https://your-foundry-resource.services.ai.azure.com/api/projects/your-project
AZURE_AI_SERVICES_ENDPOINT=https://your-foundry-resource.services.ai.azure.com
MODEL_DEPLOYMENT_NAME=gpt-5.2
FOUNDRY_AGENT_NAME=lucy
FOUNDRY_APPLICATION_NAME=lucy
USE_FOUNDRY_V2=true

# Azure AI Responses
AZURE_GPT_MODEL=gpt-5.2
AZURE_RESPONSES_ENABLED=true
AZURE_RESPONSES_REASONING_EFFORT=medium
AZURE_RESPONSES_MAX_OUTPUT_TOKENS=1200
AZURE_RESPONSES_PARALLEL_TOOL_CALLS=true
AZURE_RESPONSES_STORE=true

# Azure AI Search (Foundry project connection)
AI_SEARCH_PROJECT_CONNECTION_ID=/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/rg/providers/Microsoft.CognitiveServices/accounts/foundry/projects/project/connections/connection
AI_SEARCH_PROJECT_CONNECTION_NAME=your-connection-name
AI_SEARCH_INDEX_NAME=lucy-notices-v2
SEARCH_QUERY_TYPE=vector_semantic_hybrid
SEARCH_TOP_K=5

# Dynamics 365 Configuration
D365_CLIENT_ID=your-client-id
D365_CLIENT_SECRET=your-client-secret
D365_TENANT_ID=your-tenant-id
D365_RESOURCE_URL=https://apexclassaction.crm.dynamics.com

# Agent Portal Configuration
AGENT_PORTAL_ENABLED=true
AGENT_PORTAL_URL=http://localhost:8001
AGENT_PORTAL_API_TOKEN=replace-with-shared-secret
AGENT_PORTAL_PORT=8001
ENABLE_DEBUG_ENDPOINTS=false

# Microsoft Teams Integration
TEAMS_WEBHOOK_URL=https://your-tenant.webhook.office.com/webhookb2/...
TEAMS_APP_ID=your-teams-app-id
TEAMS_APP_PASSWORD=your-teams-app-password
TEAMS_TENANT_ID=your-tenant-id
TEAMS_AGENT_EMAILS=agent1@company.com,agent2@company.com,agent3@company.com

# Email Configuration (Optional)
SMTP_SERVER=smtp.office365.com
SMTP_PORT=587
SENDER_EMAIL=lucy@apexclassaction.com
SENDER_PASSWORD=your-email-password

# Azure Storage (for documents)
AZURE_STORAGE_CONNECTION_STRING=your-connection-string
AZURE_STORAGE_CONTAINER_NAME=your-container-name

# FastAPI HTTP wrapper for Foundry AI Gateway custom-agent registration
# When enabled, a parallel uvicorn process runs alongside Chainlit and
# exposes POST /agent/respond (auth-gated) for Foundry evals/playground.
LUCY_HTTP_ENABLED=true
LUCY_HTTP_PORT=8002
# Set false in a dedicated gateway-only Container App that exposes LUCY_HTTP_PORT.
LUCY_CHAINLIT_ENABLED=true
# Shared secret used by APIM to authenticate to /agent/respond (X-Agent-Token header)
LUCY_GATEWAY_API_TOKEN=replace-with-shared-secret
# OpenTelemetry agent ID — must match the value pasted into the Foundry
# Register Asset form's "OpenTelemetry agent ID" field. Foundry Monitor tab
# filters traces by the canonical GenAI attributes (gen_ai.agent.*). Hosted
# deployments default this to the hosted agent name.
LUCY_OTEL_AGENT_ID=lucy-aca
# Optional Chainlit progress UI inside the sync notice-retrieval tool.
# Keep disabled by default because the sync tool can run outside a Chainlit
# request context under Hosted/Gateway/worker execution.
LUCY_CHAINLIT_NOTICE_PROGRESS=false

# Daily generic notice sync job. This copies only generic case-level notice PDFs
# from Shared Documents/Active Cases/Settlements/{case}/Print/Notice packet.
SHAREPOINT_SITE_HOST=apexclassaction.sharepoint.com
SHAREPOINT_SITE_PATH=/sites/ApexClassAction
SHAREPOINT_DRIVE_NAME=Documents
SHAREPOINT_CASE_ROOT=/Shared Documents/Active Cases/Settlements
GENERIC_NOTICE_SUBPATH=Print/Notice packet
# Defaults to lucycmnotices because the current lucy-notices-v2 Search indexers
# already watch that container hourly. West storage/search remain the source of
# truth; East resources are mirrors/runtime only. Generic notices are copied
# into this single flat prefix as {case-slug}--{case-key}--{pdf-name}.
AZURE_GENERIC_NOTICE_CONTAINER=lucycmnotices
GENERIC_NOTICE_BLOB_PREFIX=generic-notices
GENERIC_NOTICE_LEDGER_BLOB=_sync/generic_notice_ledger.json
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=

OTEL_SERVICE_NAME=lucy-agent
OTEL_RESOURCE_ATTRIBUTES=service.name=lucy-agent,service.version=1.0.0
OTEL_PYTHON_LOGGING_AUTO_INSTRUMENTATION_ENABLED=true

# Logging
LOG_LEVEL=INFO
