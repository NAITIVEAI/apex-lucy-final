# Azure OpenAI (legacy)
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_ENDPOINT=https://your-endpoint.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# Azure AI Foundry
AZURE_AI_FOUNDRY_PROJECT_ENDPOINT=https://your-foundry-resource.services.ai.azure.com/api/projects/your-project
AZURE_AI_SERVICES_ENDPOINT=https://your-foundry-resource.services.ai.azure.com
MODEL_DEPLOYMENT_NAME=gpt-5.2
FOUNDRY_AGENT_NAME=lucy
USE_FOUNDRY_V2=true

# Azure AI Responses
AZURE_GPT_MODEL=gpt-5.2
AZURE_RESPONSES_ENABLED=true
AZURE_RESPONSES_REASONING_EFFORT=medium
AZURE_RESPONSES_MAX_OUTPUT_TOKENS=1200
AZURE_RESPONSES_PARALLEL_TOOL_CALLS=true
AZURE_RESPONSES_STORE=true

# Azure AI Search (Foundry project connection)
AI_SEARCH_PROJECT_CONNECTION_ID=/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/rg/providers/Microsoft.CognitiveServices/accounts/foundry/projects/project/connections/connection
AI_SEARCH_PROJECT_CONNECTION_NAME=your-connection-name
AI_SEARCH_INDEX_NAME=lucy-notices-v2
SEARCH_QUERY_TYPE=vector_semantic_hybrid
SEARCH_TOP_K=5

# Dynamics 365 Configuration
DYNAMICS_CLIENT_ID=your-client-id
DYNAMICS_CLIENT_SECRET=your-client-secret
DYNAMICS_TENANT_ID=your-tenant-id
DYNAMICS_RESOURCE_URL=https://apexclassaction.crm.dynamics.com

# Agent Portal Configuration
AGENT_PORTAL_ENABLED=true
AGENT_PORTAL_URL=http://localhost:8001
AGENT_PORTAL_PORT=8001

# Microsoft Teams Integration
TEAMS_WEBHOOK_URL=https://your-tenant.webhook.office.com/webhookb2/...
TEAMS_APP_ID=your-teams-app-id
TEAMS_APP_PASSWORD=your-teams-app-password
TEAMS_TENANT_ID=your-tenant-id
TEAMS_AGENT_EMAILS=agent1@company.com,agent2@company.com,agent3@company.com

# Email Configuration (Optional)
SMTP_SERVER=smtp.office365.com
SMTP_PORT=587
SENDER_EMAIL=lucy@apexclassaction.com
SENDER_PASSWORD=your-email-password

# Azure Storage (for documents)
AZURE_STORAGE_CONNECTION_STRING=your-connection-string
AZURE_STORAGE_CONTAINER_NAME=your-container-name

# Logging
LOG_LEVEL=INFO
